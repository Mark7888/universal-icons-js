{
  "name": "universal-icons-js",
  "version": "0.1.0",
  "description": "Universal icon generator — one source image, all target sizes and formats for React Native, Vite, PWA, Electron and more",
  "keywords": [
    "icon",
    "generator",
    "react-native",
    "vite",
    "pwa",
    "electron",
    "sharp",
    "icons",
    "favicon"
  ],
  "author": "Mark Licsauer",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mark7888/universal-icons-js.git"
  },
  "bugs": {
    "url": "https://github.com/Mark7888/universal-icons-js/issues"
  },
  "homepage": "https://github.com/Mark7888/universal-icons-js#readme",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "universal-icons": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "icons": "universal-icons",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "jiti": "^2.7.0",
    "sharp": "^0.34.5",
    "to-ico": "1.0.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/to-ico": "^1.1.3",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "eslint": "^9.28.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
